# Порт и БД
PORT=8080
DB_PATH=./data/app.db

# b2b: шифрование вебхуков СТО (без него b2b-эндпоинты отдают 503)
APP_SECRET_KEY=change-me

# auth: подпись JWT (без него auth-эндпоинты 503)
JWT_SECRET=change-me

# Операторские действия (scan-all). Пусто => выключено
ADMIN_TOKEN=

# Вход через Telegram (токен бота). Пусто => /auth/telegram выключен
TELEGRAM_BOT_TOKEN=

# Период автоскана всех СТО (напр. 10m, 1h). Пусто => шедулер выключен
B2B_SCAN_INTERVAL=
