# --- Сервер / БД ---
PORT=8082
DB_PATH=./data/app.db

# --- Рекомендации / VIN (Dev 3) ---
# LLM_MODE=live требует локальные Ollama + SearXNG; для демо без них — disabled | fixture
VIN_MODE=live
VIN_FIXTURE_FALLBACK=1
LLM_MODE=live
MAINTENANCE_RULES_PATH=data/maintenance_rules.yaml
SEARXNG_BASE_URL=http://127.0.0.1:18081
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b

# --- b2b (Dev 1): шифрование вебхуков СТО; без него b2b-эндпоинты отдают 503 ---
APP_SECRET_KEY=change-me
# Операторские действия (scan-all). Пусто => выключено
ADMIN_TOKEN=
# Период автоскана всех СТО (напр. 10m, 1h). Пусто => шедулер выключен
B2B_SCAN_INTERVAL=

# --- auth (Dev 1): подпись JWT; без него auth-эндпоинты 503 ---
JWT_SECRET=change-me
# Вход через Telegram (токен бота). Пусто => /auth/telegram выключен
TELEGRAM_BOT_TOKEN=
